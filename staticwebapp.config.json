{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/.auth/*"]
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "auth": {
    "identityProviders": {
      "customOpenIdConnectProviders": {
        "linkedin": {
          "registration": {
            "clientIdSettingName": "LINKEDIN_CLIENT_ID",
            "clientCredential": {
              "clientSecretSettingName": "LINKEDIN_CLIENT_SECRET"
            },
            "openIdConnectConfiguration": {
              "wellKnownOpenIdConfiguration": "https://www.linkedin.com/oauth/.well-known/openid-configuration"
            }
          },
          "login": {
            "scopes": ["openid", "profile", "email"]
          }
        }
      }
    }
  },
  "responseOverrides": {
    "401": {
      "statusCode": 401
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
