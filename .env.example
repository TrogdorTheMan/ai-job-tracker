# ----------------------------------------------------------------------------
# ai-job-tracker — example environment file
#
# Copy this file to ".env" and fill in your own values:
#     cp .env.example .env
#
# RULES OF THE ROAD:
#   - .env is git-ignored. NEVER commit real keys. This file ships with blanks.
#   - Every key here is YOURS. Nothing is billed to anyone but you.
#   - All of these are read server-side only (Azure Functions) and never
#     exposed to the browser.
#   - Leave a section blank and the matching feature simply turns off.
#     The plain tracker runs fine with none of these set.
# ----------------------------------------------------------------------------


# === Azure OpenAI (optional) ================================================
# Powers fit scoring, resume tailoring, and cover-letter / outreach drafting.
# Leave blank to run the tracker with no AI features.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
# Deployment names you created in your Azure OpenAI resource:
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-10-21


# === Job search connectors (each optional + independent) ====================
# Adzuna — free key at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# USAJobs — free key at https://developer.usajobs.gov/
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=


# === LinkedIn (optional) =====================================================
# The data-export import (drop in your LinkedIn .zip) works with NO keys.
# These are only needed to enable "Sign in with LinkedIn" (OpenID login).
# Register a free OAuth app at https://www.linkedin.com/developers/ to get them.
# Leave blank and users can still import their data export for full enrichment.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=


# === App / storage =========================================================
# Where application data lives. "local" uses an on-disk store for local dev;
# "azure-table" uses Azure Table Storage when deployed to a Static Web App.
DATA_BACKEND=local

# Connection string for the cloud store (only needed when DATA_BACKEND=azure-table)
AZURE_STORAGE_CONNECTION_STRING=
